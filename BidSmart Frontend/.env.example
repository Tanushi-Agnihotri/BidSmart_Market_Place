# Backend API base URL (used by lib/api.ts apiUrl helper)
VITE_API_BASE_URL=http://localhost:8081

# Google OAuth Client ID (from https://console.cloud.google.com/apis/credentials)
# Required for the "Continue with Google" button on /login.
# Authorized JavaScript origin in Google Cloud must include http://localhost:8080
VITE_GOOGLE_CLIENT_ID=

# Web3Forms access key (from https://web3forms.com)
# Used by the /contact form to deliver messages to bidsmart.marketplace@gmail.com.
VITE_WEB3FORMS_ACCESS_KEY=
